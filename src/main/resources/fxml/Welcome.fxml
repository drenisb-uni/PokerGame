<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.text.Font?>

<StackPane fx:controller="pokergame.view.controllers.WelcomeController"
           prefHeight="639.0" prefWidth="1366.0"
           stylesheets="@css/style.css" styleClass="root-pane"
           xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1">

    <children>
        <Button text="Start Game"
                onAction="#onStartButtonClicked"
                style="-fx-background-color: #2e8b57; -fx-text-fill: white; -fx-padding: 15 40; -fx-background-radius: 8; -fx-cursor: hand;">
            <font>
                <Font name="System Bold" size="24.0" />
            </font>
        </Button>
    </children>

</StackPane>