<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane fx:controller="pokergame.view.controllers.GameController"
           prefHeight="639.0" prefWidth="1366.0"
           stylesheets="@css/style.css" styleClass="root-pane"
           xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1">

    <children>
        <BorderPane>

            <top>
                <HBox alignment="CENTER" spacing="15.0" style="-fx-padding: 30 0 0 0;">
                    <ImageView fx:id="commCard1" fitHeight="140.0" fitWidth="100.0" preserveRatio="true" styleClass="card-image"/>
                    <ImageView fx:id="commCard2" fitHeight="140.0" fitWidth="100.0" preserveRatio="true" styleClass="card-image"/>
                    <ImageView fx:id="commCard3" fitHeight="140.0" fitWidth="100.0" preserveRatio="true" styleClass="card-image"/>
                    <ImageView fx:id="commCard4" fitHeight="140.0" fitWidth="100.0" preserveRatio="true" styleClass="card-image"/>
                    <ImageView fx:id="commCard5" fitHeight="140.0" fitWidth="100.0" preserveRatio="true" styleClass="card-image"/>
                </HBox>
            </top>

            <center>
                <FlowPane fx:id="playersContainer" alignment="CENTER" hgap="40.0" vgap="40.0" />
            </center>

            <bottom>
                <VBox alignment="CENTER" spacing="15.0" style="-fx-padding: 0 0 40 0;">
                    <Label fx:id="chipsInfoLabel" text="Your Chips: $1000  |  Pot: $0" styleClass="chips-text"/>

                    <HBox alignment="CENTER" spacing="20.0">
                        <Button text="Fold" onAction="#handleFold" styleClass="action-btn, fold-btn" />
                        <Button text="Call" onAction="#handleCall" styleClass="action-btn, call-btn" />
                        <Button text="Raise" onAction="#showRaisePopup" styleClass="action-btn, raise-btn" />
                    </HBox>
                </VBox>
            </bottom>

        </BorderPane>

        <StackPane fx:id="raisePopupOverlay" visible="false" style="-fx-background-color: rgba(0, 0, 0, 0.7);">

            <VBox alignment="CENTER" spacing="20.0" maxWidth="350.0" maxHeight="200.0" styleClass="popup-box">

                <Label text="Raise Amount" styleClass="popup-title"/>

                <TextField fx:id="raiseAmountInput" promptText="Enter amount..." styleClass="input-field"/>

                <HBox alignment="CENTER" spacing="15.0">
                    <Button text="All In!" onAction="#handleAllIn" styleClass="popup-btn, all-in-btn" />
                    <Button text="Confirm" onAction="#handleConfirmRaise" styleClass="popup-btn, confirm-btn" />
                    <Button text="Cancel" onAction="#hideRaisePopup" styleClass="popup-btn, cancel-btn" />
                </HBox>

            </VBox>

        </StackPane>

    </children>
</StackPane>