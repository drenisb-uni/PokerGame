<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane fx:controller="pokergame.view.controllers.LoginController"
           prefHeight="600.0" prefWidth="800.0"
           style="-fx-background-color: #1a1a1a;"
           xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1">

    <children>
        <VBox alignment="CENTER" maxWidth="800.0" prefHeight="600.0"
              style="-fx-background-color: #2b2b2b; -fx-border-color: #2e8b57; -fx-border-radius: 10; -fx-border-width: 2;">

            <padding>
                <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
            </padding>

            <children>
                <Label text="Texas Hold'em" textFill="#2e8b57">
                    <font>
                        <Font name="System Bold" size="32.0" />
                    </font>
                </Label>

                <Label text="Enter a username to join or create an account." textFill="#aaaaaa">
                    <font>
                        <Font size="14.0" />
                    </font>
                </Label>

                <TextField fx:id="usernameField" promptText="Enter Username..."
                           style="-fx-font-size: 16px; -fx-padding: 10; -fx-background-radius: 5;"/>

                <Label fx:id="errorLabel" textFill="#ff4c4c" visible="false">
                    <font>
                        <Font name="System Bold" size="12.0" />
                    </font>
                </Label>

                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false"
                        onAction="#onLoginButtonClicked"
                        style="-fx-background-color: #2e8b57; -fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold; -fx-padding: 10; -fx-background-radius: 5; -fx-cursor: hand;"
                        text="Enter Lobby" />
            </children>
        </VBox>
    </children>
</StackPane>